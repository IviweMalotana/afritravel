# AfriTravel — payment provider keys (optional)
#
# Leave these BLANK to run the demo in mock mode (no real charges, simulated
# success). Set them to switch the adapters to real-integration mode, which
# expects a backend at /api/paystack/* and /api/momo/* to hold the secrets.

# Paystack public key (pk_test_... or pk_live_...). The SECRET key must NEVER
# be exposed to the browser — keep it on your server.
VITE_PAYSTACK_PUBLIC_KEY=

# MTN MoMo subscription key for the Collections product (sandbox or production).
VITE_MOMO_SUBSCRIPTION_KEY=
